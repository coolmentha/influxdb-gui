# Normalize all text line endings to LF to keep Windows/macOS/Linux consistent.
* text=auto eol=lf

# Force these to LF regardless of platform.
*.md text eol=lf
*.rs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
